<!DOCTYPE html>
<html>
<head>

<title>SAR Tournament Manager</title>

<style>

body{
font-family:Arial;
background:#F7BACF;
text-align:center;
}

button{
margin:5px;
padding:6px 12px;
cursor:pointer;
}

table{
margin:auto;
border-collapse:collapse;
margin-top:10px;
width:auto;
}

td,th{
border:1px solid black;
padding:6px 10px;
white-space:nowrap;
}

th{
background:#ffffff55;
}

/* ONLY name column wide */
td:nth-child(2), th:nth-child(2){
min-width:320px;
white-space:normal;
}

.round{ display:none; }
.active{ display:block; }

.selected{ background:#9fd3ff; }

textarea{ width:90%; }

/* PODIUM COLORS */
.firstRow{ background:#FBC02D; }
.secondRow{ background:#B0BEC5; }
.thirdRow{ background:#cd7f32; }

</style>

</head>

<body>

<h1>SAR Tournament Manager</h1>

<button onclick="addTournament()">Add Tournament</button>

<div id="tournamentTabs"></div>

<hr>

<div id="tournamentArea"></div>

<script>

let tournaments=[]
let currentTournament=0
let mode="teams"

function addTournament(){

let name=prompt("Tournament Name")
if(!name)return

let id=tournaments.length

tournaments.push({
name:name,
rounds:[]
})

let btn=document.createElement("button")
btn.innerText=name
btn.onclick=()=>openTournament(id)

document.getElementById("tournamentTabs").appendChild(btn)

openTournament(id)

}

function openTournament(id){

currentTournament=id

let t=tournaments[id]

document.getElementById("tournamentArea").innerHTML=`

<h2>${t.name}</h2>

<h3>Mode</h3>
<select onchange="changeMode(this.value)">
<option value="teams">Teams</option>
<option value="solos">Solos</option>
</select>

<h3>Background</h3>

<input type="text" id="bg1" value="#F7BACF">
<input type="text" id="bg2" placeholder="#color1">
<input type="text" id="bg3" placeholder="#color2">

<br><br>

<button onclick="applyBG()">Apply Background</button>

<hr>

<h3>Scoring</h3>

1st <input id="s1" value="10">
2nd <input id="s2" value="8">
3rd <input id="s3" value="7">
4+ <input id="s4" value="5">
Kill <input id="sk" value="1">

<br><br>

<button onclick="addRound()">Add Round</button>
<button onclick="groupPlayers()">GROUP PEOPLE</button>
<button onclick="finishTournament()">Finished</button>

<br><br>

<h3>Paste /getplayers Output</h3>

<textarea id="pasteData" rows="10"></textarea>

<br>

<button onclick="importPaste()">Import Round</button>

<div id="roundTabs"></div>
<div id="roundContainer"></div>

<h2>Final Leaderboard</h2>

<table id="leaderboard"></table>

`

drawLeaderboard()

}

function changeMode(val){
mode=val
drawLeaderboard()
}

function applyBG(){

let single=document.getElementById("bg1").value
let g1=document.getElementById("bg2").value
let g2=document.getElementById("bg3").value

if(g1 && g2){
document.body.style.background=`linear-gradient(to right, ${g1}, ${g2})`
}else{
document.body.style.background=single
}

}

function addRound(){

let t=tournaments[currentTournament]

let num=t.rounds.length+1
t.rounds.push([])

let tab=document.createElement("button")
tab.innerText="Round "+num
tab.onclick=()=>showRound(num-1)

document.getElementById("roundTabs").appendChild(tab)

let div=document.createElement("div")
div.id="round"+num
div.className="round"

div.innerHTML=`
<h3>Round ${num}</h3>
<table>
<tr>
<th>Team</th>
<th>Player</th>
<th>Kills</th>
<th>Placement Points</th>
<th>Place</th>
</tr>
<tbody id="roundBody${num}"></tbody>
</table>
`

document.getElementById("roundContainer").appendChild(div)

showRound(num-1)

}

function showRound(i){

document.querySelectorAll(".round").forEach(r=>r.classList.remove("active"))

let div=document.getElementById("round"+(i+1))
if(div)div.classList.add("active")

}

function importPaste(){

let text=document.getElementById("pasteData").value
if(!text.trim())return

parseData(text)

}

function placementScore(place){

let s1=Number(document.getElementById("s1").value)
let s2=Number(document.getElementById("s2").value)
let s3=Number(document.getElementById("s3").value)
let s4=Number(document.getElementById("s4").value)

if(place==1)return s1
if(place==2)return s2
if(place==3)return s3
return s4

}

function parseData(text){

let t=tournaments[currentTournament]

let active=document.querySelector(".round.active")
if(!active)return

let roundIndex=Number(active.id.replace("round",""))-1

let lines=text.split("\n")
let data=[]

lines.forEach(line=>{

if(line.startsWith("pID")||line.trim()==="")return

let parts=line.trim().split(/\s+/)

let kills = Number(parts[parts.length-3])
let placement = Number(parts[parts.length-2])

// ✅ PERFECT NAME PARSER
let playerParts=[]
for(let i=1;i<parts.length;i++){
if(/^[A-F0-9]{8,}$/i.test(parts[i]) || parts[i]==="-1"){
break
}
playerParts.push(parts[i])
}

let player=playerParts.join(" ")

let score=kills*Number(document.getElementById("sk").value)+placementScore(placement)

data.push({
player,
kills,
place:placement,
score,
team:null
})

})

data.sort((a,b)=>a.place-b.place)

t.rounds[roundIndex]=data

drawRound(roundIndex)
drawLeaderboard()

}

function drawRound(i){

let body=document.getElementById("roundBody"+(i+1))
body.innerHTML=""

tournaments[currentTournament].rounds[i].forEach(p=>{

let row=body.insertRow()
row.onclick=()=>row.classList.toggle("selected")

row.insertCell(0).innerText=p.team||"-"
row.insertCell(1).innerText=p.player
row.insertCell(2).innerText=p.kills
row.insertCell(3).innerText=placementScore(p.place)
row.insertCell(4).innerText=p.place

})

}

function groupPlayers(){

if(mode==="solos") return alert("Switch to Teams mode!")

let selected=document.querySelectorAll(".selected")
if(selected.length<2)return

let teamName=prompt("Team Name")
if(!teamName)return

let t=tournaments[currentTournament]
let roundIndex=Number(document.querySelector(".round.active").id.replace("round",""))-1

selected.forEach(r=>{
let player=r.cells[1].innerText
let obj=t.rounds[roundIndex].find(p=>p.player===player)
obj.team=teamName
r.cells[0].innerText=teamName
r.classList.remove("selected")
})

drawLeaderboard()

}

function drawLeaderboard(){

let t=tournaments[currentTournament]
let table=document.getElementById("leaderboard")

if(mode==="solos"){

table.innerHTML=`<tr><th>Name</th><th>Points</th><th>Place</th></tr>`

let players={}

t.rounds.forEach(r=>{
r.forEach(p=>{
players[p.player]=(players[p.player]||0)+p.score
})
})

let sorted=Object.entries(players).sort((a,b)=>b[1]-a[1])
let place=1

sorted.forEach((p,i)=>{

if(i>0 && p[1]<sorted[i-1][1]) place++

let row=table.insertRow()

if(place===1) row.classList.add("firstRow")
if(place===2) row.classList.add("secondRow")
if(place===3) row.classList.add("thirdRow")

row.insertCell(0).innerText=p[0]
row.insertCell(1).innerText=p[1]
row.insertCell(2).innerText=place

})

return
}

// TEAMS

table.innerHTML=`<tr><th>Team</th><th>Players</th><th>Total</th><th>Place</th></tr>`

let teams={}

t.rounds.forEach(r=>{
r.forEach(p=>{

let teamName=p.team||p.player

if(!teams[teamName]){
teams[teamName]={players:new Set(), total:0}
}

teams[teamName].players.add(p.player)
teams[teamName].total+=p.score

})
})

let sorted=Object.entries(teams).sort((a,b)=>b[1].total-a[1].total)
let place=1

sorted.forEach((team,i)=>{

if(i>0 && team[1].total<sorted[i-1][1].total) place++

let row=table.insertRow()

if(place===1) row.classList.add("firstRow")
if(place===2) row.classList.add("secondRow")
if(place===3) row.classList.add("thirdRow")

row.insertCell(0).innerText=team[0]
row.insertCell(1).innerText=[...team[1].players].join(", ")
row.insertCell(2).innerText=team[1].total
row.insertCell(3).innerText=place

})

}

function finishTournament(){
localStorage.setItem("sar_tournaments",JSON.stringify(tournaments))
alert("Tournament Saved")
}

</script>

</body>
</html>
